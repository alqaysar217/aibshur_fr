rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. قواعد المجموعة المشتركة (Collection Group) ---
    // هذه القاعدة يجب أن تكون في القمة ومستقلة لضمان عمل استعلامات المجموعات (مثل البحث والمفضلة)
    // النمط {path=**} يسمح بالوصول لمجموعة "products" أينما وجدت في قاعدة البيانات
    match /{path=**}/products/{productId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn(); // للسماح بالتهيئة (Seed) للمطور
    }

    // --- 2. ملفات المستخدمين ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 3. المتاجر ---
    match /stores/{storeId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn(); // للتهيئة

      // المنتجات هنا مغطاة أيضاً بقاعدة المجموعات المشتركة أعلاه لضمان شمولية القراءة
      match /products/{productId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- 4. البيانات العامة ---
    match /ads/{id} { 
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /categories/{id} { 
      allow read: if true; 
      allow write: if isSignedIn();
    }
    match /governorates/{id} { 
      allow read: if true; 
      allow write: if isSignedIn();
    }

    // --- 5. الطلبات ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      );
    }
  }
}