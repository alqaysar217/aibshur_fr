rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. قواعد البحث الشامل (Collection Group Queries) ---
    // يجب أن تكون في أعلى مستوى لتعمل مع استعلامات collectionGroup
    // الوجبات والمنتجات هي بيانات عامة يحق للجميع تصفحها
    match /{path=**}/products/{productId} {
      allow read, list: if true; 
    }

    // التقييمات تتطلب تسجيل دخول للقراءة
    match /{path=**}/ratings/{ratingId} {
      allow read, list: if isSignedIn();
    }

    // --- 2. المتاجر والبيانات العامة ---
    match /stores/{storeId} {
      allow read, list: if true;
      allow write: if isSignedIn(); // للسماح بتهيئة البيانات

      // السماح بالوصول المباشر للمنتجات داخل المتجر
      match /products/{productId} {
        allow read, list: if true;
      }
    }

    match /ads/{id} { allow read: if true; }
    match /categories/{id} { allow read: if true; }
    match /governorates/{id} { allow read: if true; }

    // --- 3. ملفات المستخدمين وبياناتهم الخاصة ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // جميع المجموعات الفرعية (الطلبات، المحفظة، المفضلة، إلخ)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 4. الطلبات العامة ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      );
    }
  }
}