
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. قواعد البحث الشامل (Collection Group) ---
    // هذه القاعدة ضرورية جداً لعمل صفحة "المفضلة" والبحث الذكي عن المنتجات
    // يجب أن تكون في أعلى مستوى لضمان عمل استعلامات collectionGroup
    match /{path=**}/products/{productId} {
      allow read, list: if true; 
    }

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. المتاجر والبيانات العامة ---
    match /stores/{storeId} {
      allow read, list: if true;
      allow write: if isSignedIn();

      match /products/{productId} {
        allow read, list: if true;
      }
    }

    match /ads/{id} { allow read: if true; }
    match /categories/{id} { allow read: if true; }
    match /governorates/{id} { allow read: if true; }

    // --- 3. ملفات المستخدمين ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 4. الطلبات العامة ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      );
    }
  }
}
