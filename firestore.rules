
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is a verified Admin
    function isAdmin() {
      // Primary check: Official Admin Phone in Auth Token
      let isAdminPhone = request.auth != null && 
             (request.auth.token.phone_number == '+967775258830' || 
              request.auth.token.phone_number == '+967770636008');
      
      // Fallback: Check the users collection by UID (Crucial for Anonymous Prototype Sync)
      // This allows the Admin Dashboard to work during the 'sync' phase
      let isDocAdmin = request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == 'admin';
             
      return isAdminPhone || isDocAdmin;
    }

    // Cities: Everyone can read, only Admin can write
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users & Drivers: Admin has FULL access. Users see their own data.
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      match /{allSubcollections=**} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }
    }

    match /drivers/{driverId=**} {
      allow read, write: if isAdmin();
    }
    
    // Orders: Admin has FULL access. Customers see their own orders.
    match /orders/{orderId} {
      allow read, write: if isAdmin() || (request.auth != null && (resource == null || resource.data.customerId == request.auth.uid || resource.data.userId == request.auth.uid));
      match /{allSubcollections=**} {
        allow read, write: if isAdmin() || (request.auth != null);
      }
    }

    // Support Collection Groups for Admin Queries
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin() || (request.auth != null);
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();
      match /{allSub=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{path=**}/products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
