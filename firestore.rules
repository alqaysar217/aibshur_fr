/**
 * ### Firebase Security Rules for "أبشر" Delivery Platform
 * 
 * #### Core Philosophy
 * This ruleset implements a strict identity-based authorization model designed for high performance
 * and "Authorization Independence." By matching wildcards in the document paths to internal 
 * ownership fields, we ensure that security decisions are atomic and do not require expensive 
 * cross-document lookups (get() calls) in most scenarios.
 * 
 * #### Data Structure
 * - **User/Driver Private Trees**: Personal profiles, wallets, transactions, and notifications are 
 *   nested under `/users/{userId}` or `/drivers/{driverId}`. Access is restricted to the account owner.
 * - **Global Public Collections**: Categories, Governorates, Ads, Offers, and Coupons are top-level 
 *   collections that are publicly readable but only writeable by users with verified Admin privileges.
 * - **Merchant Domain**: Stores and Products are publicly readable. Specific store management 
 *   privileges are handled via denormalized `adminUserId` and `storeAdminUserId` fields on the 
 *   respective documents.
 * - **Orders & Ratings**: Orders are shared between the customer (path owner) and the assigned driver. 
 *   Ratings are initially private to the creator but allow for public reading for aggregation.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isStoreManager(storeData) {
      return isSignedIn() && storeData.adminUserId == request.auth.uid;
    }

    function isProductManager(productData) {
      return isSignedIn() && (productData.storeAdminUserId == request.auth.uid || productData.adminUserId == request.auth.uid);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Product Collection Group Query Support
     * Allows searching for products across all stores globally.
     * This is critical for Favorites and Global Search.
     */
    match /{path=**}/products/{productId} {
      allow read: if true;
      allow create: if isSignedIn(); // Managed by application logic & storeAdminUserId
      allow update, delete: if isAdmin() || isProductManager(resource.data);
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /wallet/{walletId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.ownerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(userId);
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /orders/{orderId} {
        allow get: if isOwner(userId) || (isSignedIn() && resource.data.driverId == request.auth.uid);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || (isSignedIn() && resource.data.driverId == request.auth.uid));
        allow delete: if isAdmin();

        match /ratings/{ratingId} {
          allow get, list: if true;
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId) || isAdmin();
        }
      }

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isAdmin();
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /donations/{donationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isAdmin();
      }

      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }

      match /loyaltyPointTransactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isAdmin();
      }
    }

    match /drivers/{driverId} {
      allow get, list: if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId) || isAdmin();
      allow update: if isExistingOwner(driverId) || isAdmin();
      allow delete: if isAdmin();

      match /wallet/{walletId} {
        allow get, list: if isOwner(driverId) || isAdmin();
        allow create, update: if isOwner(driverId) || isAdmin();
        allow delete: if isAdmin();
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(driverId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }

      match /notifications/{notificationId} {
        allow get, list: if isOwner(driverId);
        allow create: if isAdmin();
        allow update, delete: if isExistingOwner(driverId);
      }
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isStoreManager(resource.data) || isAdmin();
      allow delete: if isAdmin();
      
      // Allow products subcollection specifically
      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin() || isStoreManager(get(/databases/$(database)/documents/stores/$(storeId)).data);
      }
    }

    match /categories/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /governorates/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ads/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /offers/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /coupons/{id} {
      allow get, list: if true; 
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}