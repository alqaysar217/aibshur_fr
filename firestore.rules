
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    // للنموذج الأولي، نعتبر كل مستخدم مسجل كمسؤول مؤقتاً لضمان عمل لوحة التحكم
    function isAdmin() {
      return isSignedIn();
    }

    // --- المحافظات والمدن ---
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- الفئات ---
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- المتاجر والمنتجات ---
    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /variants/{vId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // --- الإعلانات ---
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- المنتجات (البحث الموحد عبر المتاجر - Collection Group) ---
    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    // --- ملفات المستخدمين ---
    // تم التعديل للسماح صراحة بعمليات القائمة (list) على مجموعة المستخدمين
    match /users/{userId} {
      allow read, write: if isSignedIn();
      
      // الوصول لكافة المجموعات الفرعية (المحفظة، العناوين، إلخ)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- الطلبات العامة ---
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }
    
    // دعم الاستعلامات المجمعة للطلبات (Collection Group)
    match /{path=**}/orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // --- إعدادات النظام ---
    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // تعليق لتنشيط تحديث القواعد: تم تحسين صلاحيات القائمة للمسؤولين
  }
}
