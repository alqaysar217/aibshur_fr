
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. قواعد البحث الشامل (Collection Group Queries) ---
    // يجب أن تكون خارج أي تداخلات أخرى لتعمل بشكل صحيح مع استعلامات collectionGroup
    match /{path=**}/products/{productId} {
      allow read, list: if true; // السماح للجميع برؤية الوجبات لضمان عمل البحث والمفضلة
    }

    match /{path=**}/ratings/{ratingId} {
      allow read, list: if request.auth != null;
    }

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. المتاجر والبيانات العامة ---
    match /stores/{storeId} {
      allow read, list: if true;
      allow write: if isSignedIn();

      // القواعد الفرعية للمنتجات داخل المتجر (للوصول المباشر)
      match /products/{productId} {
        allow read, list: if true;
      }
    }

    match /ads/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /categories/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /governorates/{id} { allow read: if true; }

    // --- 3. ملفات المستخدمين وبياناتهم الخاصة ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 4. الطلبات العامة ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
    }
  }
}
