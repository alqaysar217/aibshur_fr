
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // التحقق من صلاحية المسؤول
    // للنموذج الأولي، نعتبر كل مستخدم مسجل كمسؤول مؤقتاً لضمان عمل لوحة التحكم
    // سيتم تشديد هذه القواعد عند الانتقال للإنتاج وربط أرقام الهواتف حقيقياً
    function isAdmin() {
      return isSignedIn();
    }

    // --- مجموعات البيانات العامة ---
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /variants/{vId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // --- المنتجات (البحث الموحد) ---
    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    // --- ملفات المستخدمين والمحفظة ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /wallet/{id} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /orders/{orderId} {
        allow read, write: if isSignedIn();
      }
      
      match /transactions/{tId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // --- الطلبات العامة ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }

    // --- إعدادات النظام ---
    match /admin_settings/settings {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
