
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. القواعد العامة للمجموعات المشتركة (مهمة جداً للبحث والمفضلة)
    match /{path=**}/products/{productId} {
      allow read: if request.auth != null;
    }

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- قواعد المجموعات ---

    match /users/{userId} {
      // السماح بإنشاء الوثيقة إذا كان المستخدم هو المالك وأرسل الـ ID الصحيح
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow get, list, update: if isOwner(userId);
      allow delete: if false;

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /stores/{storeId} {
      allow read: if isSignedIn();
      allow write: if false; // للمسؤولين فقط من لوحة التحكم

      match /products/{productId} {
        allow read: if isSignedIn();
      }
    }

    match /categories/{id} { allow read: if isSignedIn(); }
    match /offers/{id} { allow read: if isSignedIn(); }
    match /ads/{id} { allow read: if isSignedIn(); }
    match /governorates/{id} { allow read: if isSignedIn(); }
    match /roles_admin/{adminId} { allow read: if isSignedIn(); }
  }
}
