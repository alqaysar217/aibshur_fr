
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is a verified Admin
    function isAdmin() {
      // 1. Check Phone in Auth Token (Official Method)
      let isAdminPhone = request.auth != null && (
        request.auth.token.phone_number == '+967775258830' || 
        request.auth.token.phone_number == '+967770636008'
      );
      
      // 2. Check Firestore Document (Prototype/Fallback Method)
      // We use a helper variable to safely access the document
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let isDocAdmin = request.auth != null && exists(userPath) && get(userPath).data.type == 'admin';
             
      return isAdminPhone || isDocAdmin;
    }

    // Users: Admin can list/manage all. Users can manage their own.
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Orders: Admin has full access. Customers see their own.
    match /orders/{orderId} {
      allow read, write: if isAdmin() || (request.auth != null && (resource == null || resource.data.customerId == request.auth.uid || request.resource.data.customerId == request.auth.uid));
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Cities, Stores, etc: Public read, Admin write
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Shared access for subcollections in collectionGroup queries if needed
    match /{path=**}/products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
