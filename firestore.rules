rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict Ownership and Database-Backed Access Control (DBAC) model. 
     */

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION GROUP RULES (CRITICAL FOR SEARCH & FAVORITES) ---
    // These must be at the top level to allow querying across all stores
    match /{path=**}/products/{productId} {
      allow read, get, list: if isSignedIn();
      // Write permissions are handled in the specific store path below
    }

    // --- Standard Collection Rules ---

    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      match /wallet/{document} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      }

      match /loyalty_points/{document} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      }

      match /{collection}/{id} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isAdmin();
      }
    }

    match /drivers/{driverId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(driverId) && request.resource.data.id == driverId;
      allow update: if isExistingOwner(driverId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(storeId) && request.resource.data.id == storeId;
      allow update: if isExistingOwner(storeId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      match /products/{productId} {
        allow create: if isOwner(storeId) && request.resource.data.storeId == storeId;
        allow update: if isOwner(storeId) && resource != null && request.resource.data.storeId == resource.data.storeId;
        allow delete: if isOwner(storeId) && resource != null;
      }
    }

    match /categories/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /offers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /coupons/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /governorates/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /ads/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}