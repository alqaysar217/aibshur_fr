rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة (Helpers) ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- القواعد (Rules) ---

    // 1. البيانات العامة: (المتاجر، المنتجات، الأقسام، العروض، الإعلانات، المحافظات)
    // نسمح للجميع (حتى غير المسجلين) بالقراءة لتصفح التطبيق
    match /stores/{storeId} {
      allow read, get, list: if true;
      match /products/{productId} {
        allow read, get, list: if true;
      }
    }

    // قاعدة البحث الشامل للمنتجات (ضرورية للمفضلة والبحث)
    match /{path=**}/products/{productId} {
      allow read, get, list: if true;
    }

    match /categories/{id} { allow read: if true; }
    match /offers/{id} { allow read: if true; }
    match /ads/{id} { allow read: if true; }
    match /governorates/{id} { allow read: if true; }

    // 2. بيانات المستخدمين والمندوبين (حماية الخصوصية)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if isOwner(driverId);
    }

    // 3. الطلبات (Orders): المالك أو المندوب فقط
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
    }

    // 4. التقييمات والكوبونات
    match /ratings/{id} { 
      allow read: if true;
      allow create: if isSignedIn(); 
    }
    match /coupons/{id} { 
      allow read: if isSignedIn(); 
    }
  }
}