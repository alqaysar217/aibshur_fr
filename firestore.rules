rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. قاعدة المجموعات المشتركة (مهمة جداً للبحث والمفضلة) ---
    // هذه القاعدة يجب أن تكون في القمة وخارج أي تداخل لتسمح باستعلامات collectionGroup
    match /{path=**}/products/{productId} {
      // الوجبات بيانات عامة يجب أن تظهر للجميع لنجاح تجربة الاكتشاف
      allow read, list: if true;
    }

    // --- 2. دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 3. المتاجر (البيانات العامة) ---
    match /stores/{storeId} {
      allow read, list: if true; 
      // منع الكتابة العشوائية إلا للمسؤولين (أو عبر كود التهيئة حالياً)
      allow write: if isSignedIn();

      // المنتجات هنا مغطاة أيضاً بالقاعدة رقم 1 أعلاه
      match /products/{productId} {
        allow read, list: if true;
        allow write: if isSignedIn();
      }
    }

    // --- 4. ملفات المستخدمين (خصوصية تامة) ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // التنبيهات، الطلبات، المحفظة داخل ملف المستخدم
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 5. البيانات المفتوحة الأخرى ---
    match /ads/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /categories/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /governorates/{id} { allow read: if true; allow write: if isSignedIn(); }

    // --- 6. الطلبات (صلاحيات مشتركة بين العميل والمندوب) ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      );
    }
  }
}