
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // السماح بالبحث الشامل للمنتجات عبر المجموعات
    match /{path=**}/products/{productId} {
      allow read, list: if true;
    }

    // السماح للمسجلين بإنشاء المتاجر والمنتجات (لغرض التهيئة والتطوير)
    match /stores/{storeId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      
      match /products/{productId} {
        allow read: if true;
        allow create, update: if isSignedIn();
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
    }

    match /ads/{id} { allow read: if true; allow create: if isSignedIn(); }
    match /categories/{id} { allow read: if true; allow create: if isSignedIn(); }
    match /governorates/{id} { allow read: if true; }
  }
}
