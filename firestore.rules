rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is a verified Admin
    function isAdmin() {
      let uid = request.auth.uid;
      let userDocPath = /databases/$(database)/documents/users/$(uid);
      return request.auth != null && (
        uid in ['mV7AQV2Mm6MDRpe5eSxskxNRVn73', 'Dn5QW71UUNVTo5XmOlfBrCfCmFO2'] ||
        (exists(userDocPath) && (get(userDocPath).data.role == 'admin' || get(userDocPath).data.type == 'admin')) ||
        request.auth.token.phone_number in ['+967775258830', '+967770636008']
      );
    }

    // Cities, Stores, Categories, Ads: Public read, Admin write
    match /cities/{cityId} { allow read: if true; allow write: if isAdmin(); }
    match /stores/{storeId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
      match /{allSubcollections=**} { allow read: if true; allow write: if isAdmin(); }
    }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /ads/{adId} { allow read: if true; allow write: if isAdmin(); }

    // Users: Admin can list/manage all. Users can manage their own.
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Orders: Admin has full access. Customers see their own.
    match /orders/{orderId} {
      allow read, write: if isAdmin() || (request.auth != null && (resource == null || resource.data.customerId == request.auth.uid || request.resource.data.customerId == request.auth.uid));
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Shared access for subcollections in collectionGroup queries
    match /{path=**}/products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}