
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    // التحقق من صلاحية المسؤول
    // للنموذج الأولي، نعتبر كل مستخدم مسجل كمسؤول مؤقتاً لضمان عمل لوحة التحكم
    function isAdmin() {
      return isSignedIn();
    }

    // --- مجموعات البيانات العامة ---
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /variants/{vId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // --- المنتجات (البحث الموحد عبر المتاجر) ---
    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    // --- ملفات المستخدمين ---
    // تم التصحيح لضمان السماح بعمليات القائمة (list) لمسؤولي النظام
    match /users/{userId} {
      allow read, write: if isSignedIn();
      
      // الوصول لكافة المجموعات الفرعية (المحفظة، العناوين، التنبيهات، الطلبات الفرعية)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- الطلبات ---
    // السماح بالوصول للطلبات سواء كانت في الجذر أو كمجموعة فرعية للمستخدم
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }
    
    match /{path=**}/orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // --- إعدادات النظام ---
    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- الإعلانات ---
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
