
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // التحقق من صلاحية المسؤول
    // للنموذج الأولي، نعتبر كل مستخدم مسجل كمسؤول مؤقتاً لضمان عمل لوحة التحكم
    function isAdmin() {
      return isSignedIn();
    }

    // --- مجموعات البيانات العامة ---
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /variants/{vId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // --- المنتجات (البحث الموحد) ---
    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    // --- ملفات المستخدمين والبيانات التابعة ---
    // تم التوسيع للسماح للوحة الإدارة بجلب القوائم
    match /users/{userId} {
      allow read, write: if isSignedIn();
      
      // السماح بالوصول لكافة المجموعات الفرعية (المحفظة، العناوين، التنبيهات)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- الطلبات العامة ---
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // --- إعدادات النظام ---
    match /admin_settings/settings {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
