
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. قواعد البحث الشامل (Collection Group Queries) ---
    // يجب أن تكون خارج أي بلوك آخر لتعمل بشكل صحيح مع استعلامات المجموعات
    match /{path=**}/products/{productId} {
      allow read, list: if true; 
    }

    match /{path=**}/ratings/{ratingId} {
      allow read, list: if true;
    }

    // --- 2. المتاجر والبيانات العامة ---
    match /stores/{storeId} {
      allow read: if true;
      allow write: if isSignedIn(); // للمطور لتهيئة البيانات

      match /products/{productId} {
        allow read: if true;
      }
    }

    match /ads/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /categories/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /governorates/{id} { allow read: if true; }

    // --- 3. ملفات المستخدمين وبياناتهم الخاصة ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // قواعد فرعية للطلبات والمحفظة داخل وثيقة المستخدم
      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
      }
      match /wallet/{walletId} {
        allow read, write: if isOwner(userId);
      }
      match /donations/{id} {
        allow read, write: if isOwner(userId);
      }
      match /subscriptions/{id} {
        allow read, write: if isOwner(userId);
      }
      match /notifications/{id} {
        allow read, write: if isOwner(userId);
      }
      match /loyaltyPointTransactions/{id} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 4. الطلبات العامة (للمندوبين والربط) ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
    }
  }
}
