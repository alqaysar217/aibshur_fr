
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    // للنموذج الأولي، نعتبر كل مستخدم مسجل كمسؤول مؤقتاً لضمان عمل لوحة التحكم
    function isAdmin() {
      return isSignedIn();
    }

    // --- المجموعات العامة ---
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /variants/{vId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // --- المنتجات (البحث الموحد عبر المتاجر) ---
    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    // --- ملفات المستخدمين ---
    // السماح بالقراءة والقائمة لكافة المستخدمين المسجلين في مرحلة النموذج الأولي
    match /users {
      allow read, list: if isSignedIn();
    }

    match /users/{userId} {
      // السماح بالقراءة والكتابة للمستخدمين المسجلين
      allow read, write: if isSignedIn();
      
      // الوصول لكافة المجموعات الفرعية (المحفظة، العناوين، التنبيهات، إلخ)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- الطلبات ---
    // السماح بالقائمة (List) لمجموعة الطلبات - أساسي للوحة الإدارة
    match /orders {
      allow read, list: if isSignedIn();
    }

    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }
    
    // دعم الاستعلامات المجمعة للطلبات (Collection Group)
    match /{path=**}/orders/{orderId} {
      allow read, write, list: if isSignedIn();
    }

    // --- إعدادات النظام ---
    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- الإعلانات ---
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
