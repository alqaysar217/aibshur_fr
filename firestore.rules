rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. قواعد المجموعات المشتركة (Collection Group) ---
    // يجب أن تكون في القمة لتمكين البحث الشامل عبر كل المتاجر
    match /{path=**}/products/{productId} {
      // المنتجات والوجبات هي بيانات عامة يجب أن تظهر للجميع لنجاح تجربة البحث
      allow read, list: if true;
      allow write: if isSignedIn(); 
    }

    // --- 2. المتاجر والبيانات العامة ---
    match /stores/{storeId} {
      allow read, list: if true; // القائمة العامة للمتاجر
      allow write: if isSignedIn(); // فقط للمسؤولين أو التهيئة

      // المنتجات هنا مغطاة أيضاً بقاعدة المجموعات المشتركة أعلاه
      match /products/{productId} {
        allow read, list: if true;
        allow write: if isSignedIn();
      }
    }

    // --- 3. ملفات المستخدمين ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 4. البيانات العامة المفتوحة ---
    match /ads/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /categories/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /governorates/{id} { allow read: if true; allow write: if isSignedIn(); }

    // --- 5. الطلبات ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid
      );
    }
  }
}