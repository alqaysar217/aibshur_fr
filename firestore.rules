rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة (Helpers) ---
    
    // التأكد من أن المستخدم سجل دخوله
    function isSignedIn() {
      return request.auth != null;
    }

    // التأكد من أن المستخدم هو صاحب البيانات
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- القواعد (Rules) ---

    // 1. البيانات العامة: السماح للجميع بالقراءة (لتمكين التصفح قبل تسجيل الدخول)
    // تشمل المتاجر، المنتجات داخلها، الأقسام، العروض، والمحافظات
    match /stores/{storeId} {
      allow read, get, list: if true;
      match /products/{productId} {
        allow read, get, list: if true;
      }
    }

    // قاعدة البحث الشامل (Collection Group) للمنتجات
    // ضرورية جداً لعمل صفحة "المفضلة" والبحث الذكي عبر كافة المتاجر
    match /{path=**}/products/{productId} {
      allow read, get, list: if true;
    }

    match /categories/{id} { allow read: if true; }
    match /offers/{id} { allow read: if true; }
    match /ads/{id} { allow read: if true; }
    match /governorates/{id} { allow read: if true; }

    // 2. بيانات المستخدمين: حماية الخصوصية (المالك فقط)
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // المجموعات الفرعية (المحفظة، التنبيهات، الطلبات الخاصة، إلخ)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // 3. الطلبات المركزية (Orders): المالك أو المندوب الموكل إليه
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.driverId == request.auth.uid);
    }

    // 4. التقييمات والكوبونات: للمسجلين فقط
    match /coupons/{id} { allow read: if isSignedIn(); }
    match /ratings/{id} { allow read: if isSignedIn(); allow create: if isSignedIn(); }
  }
}