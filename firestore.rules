rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. القواعد العامة للمجموعات المشتركة (يجب أن تكون في القمة للبحث والمفضلة)
    match /{path=**}/products/{productId} {
      allow get, list: if request.auth != null;
    }

    match /{path=**}/stores/{storeId} {
      allow get, list: if request.auth != null;
    }

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- قواعد المجموعات التفصيلية ---

    match /users/{userId} {
      // السماح بالإنشاء والتحديث فقط إذا كان المستخدم هو المالك وأرسل الـ ID الصحيح
      allow create, update: if isOwner(userId) && (request.resource.data.id == userId || !exists(/databases/$(database)/documents/users/$(userId)));
      allow get, list: if isOwner(userId);
      allow delete: if false;

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /stores/{storeId} {
      allow read, get, list: if isSignedIn();
      allow write: if false; 

      match /products/{productId} {
        allow read, get, list: if isSignedIn();
      }
    }

    match /categories/{id} { allow read: if isSignedIn(); }
    match /offers/{id} { allow read: if isSignedIn(); }
    match /ads/{id} { allow read: if isSignedIn(); }
    match /governorates/{id} { allow read: if isSignedIn(); }
    match /roles_admin/{adminId} { allow read: if isSignedIn(); }
  }
}