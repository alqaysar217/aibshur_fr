rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. قواعد المجموعات المشتركة (Collection Group) - يجب أن تكون في القمة وبشكل صريح
    // تسمح بالبحث عن "المنتجات" في كافة المسارات (ضروري لصفحة البحث والمفضلة)
    match /{path=**}/products/{productId} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }

    // 2. وظائف المساعدة العامة
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 3. قواعد المجموعات العادية
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();

      match /wallet/{walletId} {
        allow read, write: if isOwner(userId);
      }

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /orders/{orderId} {
        allow get: if isOwner(userId) || (isSignedIn() && resource.data.driverId == request.auth.uid);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || (isSignedIn() && resource.data.driverId == request.auth.uid);

        match /ratings/{ratingId} {
          allow read: if true;
          allow create: if isOwner(userId);
        }
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
      }

      match /donations/{donationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /subscriptions/{subscriptionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /loyaltyPointTransactions/{transactionId} {
        allow read: if isOwner(userId);
      }
    }

    match /drivers/{driverId} {
      allow read, update: if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId) || isAdmin();

      match /wallet/{walletId} {
        allow read, write: if isOwner(driverId);
      }
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.adminUserId == request.auth.uid || isAdmin());
      
      // قواعد إضافية للمنتجات داخل المتجر (اختيارية كدعم إضافي)
      match /products/{productId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /governorates/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
    }
  }
}