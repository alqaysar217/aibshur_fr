
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- دالات مساعدة ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // التحقق من صلاحية المسؤول عبر رقم الهاتف
    function isAdmin() {
      let adminData = get(/databases/$(database)/documents/admin_settings/settings).data;
      return isSignedIn() && (
        request.auth.token.phone_number in adminData.allowedAdmins ||
        request.auth.token.phone_number.replace('\\+967', '') in adminData.allowedAdmins
      );
    }

    // --- مجموعات البيانات العامة ---
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
        
        match /variants/{vId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }

    // --- المنتجات (البحث الموحد) ---
    match /{path=**}/products/{productId} {
      allow read: if true;
    }

    // --- ملفات المستخدمين والمحفظة ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      match /wallet/{id} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin(); // الإدارة فقط تشحن الرصيد برمجياً
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- الطلبات ---
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
    }

    // --- إعدادات النظام ---
    match /admin_settings/settings {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
