rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. قاعدة البحث الشامل (Collection Group) - يجب أن تكون في القمة تماماً
    // تسمح بالبحث عن "products" في أي مكان في قاعدة البيانات
    match /{path=**}/products/{productId} {
      allow read, get, list: if true;
    }

    // 2. وظائف المساعدة
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 3. قواعد المستخدمين والبيانات الخاصة
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      // السماح بالوصول لكل المجموعات الفرعية للمستخدم (طلبات، محفظة، الخ)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /drivers/{driverId} {
      allow read, write: if isOwner(driverId) || isAdmin();
      match /{allSubcollections=**} {
        allow read, write: if isOwner(driverId) || isAdmin();
      }
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.adminUserId == request.auth.uid || isAdmin());
      
      match /products/{productId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // 4. قواعد البيانات العامة
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /governorates/{id} { allow read: if true; allow write: if isAdmin(); }
    match /ads/{id} { allow read: if true; allow write: if isAdmin(); }
    match /offers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin(); }
    match /roles_admin/{adminUid} { allow get: if isSignedIn(); }
  }
}