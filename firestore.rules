/**
 * ### Firebase Security Rules for "أبشر" Delivery Platform
 * 
 * #### Core Philosophy
 * This ruleset implements a strict identity-based authorization model designed for high performance
 * and "Authorization Independence." By matching wildcards in the document paths to internal 
 * ownership fields, we ensure that security decisions are atomic and do not require expensive 
 * cross-document lookups (get() calls) in most scenarios.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. COLLECTION GROUP RULES (MUST BE AT THE TOP LEVEL) ---
    // This allows collectionGroup('products') queries to work globally.
    // Necessary for smart search and favorites features.
    match /{path=**}/products/{productId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.storeAdminUserId == request.auth.uid) ||
        (request.resource != null && request.resource.data.storeAdminUserId == request.auth.uid)
      );
    }

    // --- 2. GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isStoreManager(storeData) {
      return isSignedIn() && storeData.adminUserId == request.auth.uid;
    }

    // --- 3. COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /wallet/{walletId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.ownerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(userId);
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /orders/{orderId} {
        allow get: if isOwner(userId) || (isSignedIn() && resource.data.driverId == request.auth.uid);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || (isSignedIn() && resource.data.driverId == request.auth.uid));
        allow delete: if isAdmin();

        match /ratings/{ratingId} {
          allow get, list: if true;
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId) || isAdmin();
        }
      }

      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isAdmin();
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /donations/{donationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isAdmin();
      }

      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }

      match /loyaltyPointTransactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isAdmin();
      }
    }

    match /drivers/{driverId} {
      allow get, list: if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId) || isAdmin();
      allow update: if isExistingOwner(driverId) || isAdmin();
      allow delete: if isAdmin();

      match /wallet/{walletId} {
        allow get, list: if isOwner(driverId) || isAdmin();
        allow create, update: if isOwner(driverId) || isAdmin();
        allow delete: if isAdmin();
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(driverId) || isAdmin();
        allow create, update, delete: if isAdmin();
      }

      match /notifications/{notificationId} {
        allow get, list: if isOwner(driverId);
        allow create: if isAdmin();
        allow update, delete: if isExistingOwner(driverId);
      }
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isStoreManager(resource.data) || isAdmin();
      allow delete: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isStoreManager(get(/databases/$(database)/documents/stores/$(storeId)).data) || isAdmin();
      }
    }

    match /categories/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /governorates/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ads/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /offers/{id} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /coupons/{id} {
      allow get, list: if true; 
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}