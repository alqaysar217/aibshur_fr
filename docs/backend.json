
{
  "entities": {
    "User": {
      "description": "بيانات العميل والمندوب",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string", "enum": ["customer", "driver", "admin"] },
        "favoritesStoreIds": { "type": "array" },
        "favoritesProductIds": { "type": "array" },
        "loyaltyPoints": { "type": "number" },
        "subscriptionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "City": {
      "description": "المحافظات والمدن المتاحة",
      "properties": {
        "id": { "type": "string" },
        "cityName": { "type": "string" },
        "supportNumber": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Store": {
      "description": "المتاجر والمطاعم",
      "properties": {
        "id": { "type": "string" },
        "cityId": { "type": "string", "description": "Reference to City" },
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "coverImage": { "type": "string" },
        "location": { "type": "object", "description": "Geopoint" },
        "rating": { "type": "number" },
        "deliveryTime": { "type": "number", "description": "In minutes" },
        "isOpen": { "type": "boolean" },
        "isTopRated": { "type": "boolean" }
      }
    },
    "Product": {
      "description": "المنتجات والوجبات",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "filterId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "price": { "type": "number" },
        "hasVariants": { "type": "boolean" }
      }
    },
    "Order": {
      "description": "نظام الطلبات المتكامل",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "driverId": { "type": "string" },
        "storeId": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "onWay", "delivered", "canceled"] },
        "paymentMethod": { "type": "string" },
        "location": { "type": "object", "description": "Geopoint" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AdminSettings": {
      "description": "إعدادات النظام العليا",
      "properties": {
        "allowedAdmins": { "type": "array", "description": "Phone numbers list" },
        "vipSilverPrice": { "type": "number" },
        "vipGoldPrice": { "type": "number" },
        "pointsToCashRate": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/cities/{cityId}": { "schema": "City" },
    "/stores/{storeId}": { "schema": "Store" },
    "/stores/{storeId}/products/{productId}": { "schema": "Product" },
    "/stores/{storeId}/products/{productId}/variants/{vId}": { "description": "خيارات المنتج" },
    "/orders/{orderId}": { "schema": "Order" },
    "/users/{userId}": { "schema": "User" },
    "/users/{userId}/wallet/{id}": { "description": "محفظة المستخدم" },
    "/admin_settings/settings": { "schema": "AdminSettings" }
  }
}
