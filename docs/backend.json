{
  "entities": {
    "User": {
      "description": "بيانات العميل",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "favoritesStoreIds": { "type": "array" },
        "favoritesProductIds": { "type": "array" },
        "loyaltyPoints": { "type": "number" }
      }
    },
    "Driver": {
      "description": "بيانات المندوب",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "vehicleType": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "busy"] }
      }
    },
    "Store": {
      "description": "المتاجر والمطاعم",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "categoryIds": { "type": "array" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      }
    },
    "Product": {
      "description": "الوجبات والمنتجات",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Order": {
      "description": "الطلبات",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "storeId": { "type": "string" },
        "driverId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "on_the_way", "delivered"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/drivers/{driverId}": { "schema": "Driver" },
    "/stores/{storeId}": { "schema": "Store" },
    "/stores/{storeId}/products/{productId}": { "schema": "Product" },
    "/orders/{orderId}": { "schema": "Order" },
    "/categories/{id}": { "description": "الأقسام" },
    "/governorates/{id}": { "description": "المحافظات" },
    "/ads/{id}": { "description": "الإعلانات" }
  }
}