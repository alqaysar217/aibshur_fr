
{
  "entities": {
    "User": {
      "description": "بيانات العميل",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "favoritesStoreIds": { "type": "array" },
        "favoritesProductIds": { "type": "array" },
        "loyaltyPoints": { "type": "number" },
        "subscriptionId": { "type": "string" }
      }
    },
    "Address": {
      "description": "عنوان التوصيل",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "description": "مثال: المنزل، العمل" },
        "city": { "type": "string" },
        "details": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "description": "التنبيهات والرسائل",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["order_status", "promotion", "system"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Store": {
      "description": "المتاجر والمطاعم",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "categoryIds": { "type": "array" },
        "address": { "type": "string" },
        "status": { "type": "string" },
        "averageRating": { "type": "number" }
      }
    },
    "Product": {
      "description": "الوجبات والمنتجات",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "storeId": { "type": "string" }
      }
    },
    "Order": {
      "description": "الطلبات",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "storeId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "on_the_way", "delivered"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User" },
    "/users/{userId}/addresses/{addressId}": { "schema": "Address" },
    "/users/{userId}/notifications/{notifId}": { "schema": "Notification" },
    "/stores/{storeId}": { "schema": "Store" },
    "/stores/{storeId}/products/{productId}": { "schema": "Product" },
    "/orders/{orderId}": { "schema": "Order" },
    "/categories/{id}": { "description": "الأقسام" },
    "/governorates/{id}": { "description": "المحافظات" }
  }
}
