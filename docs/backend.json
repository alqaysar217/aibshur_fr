{
  "entities": {
    "User": {
      "title": "User",
      "description": "بيانات العميل الشخصية والمفضلة",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "favoritesStoreIds": { "type": "array", "items": { "type": "string" } },
        "favoritesProductIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "phone"]
    },
    "Store": {
      "title": "Store",
      "description": "بيانات المتجر أو المطعم",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "address": { "type": "string" },
        "categoryIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["open", "closed"] }
      }
    },
    "Product": {
      "title": "Product",
      "description": "بيانات الوجبة أو المنتج",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "بيانات الطلب"،
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "storeId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "on_the_way", "delivered"] }
      }
    }
  },
  "auth": {
    "providers": ["phone", "google.com"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "ملفات المستخدمين" },
    "/stores/{storeId}": { "schema": "Store", "description": "المتاجر" },
    "/stores/{storeId}/products/{productId}": { "schema": "Product", "description": "منتجات المتجر" },
    "/orders/{orderId}": { "schema": "Order", "description": "الطلبات" }
  }
}