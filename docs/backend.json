
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "بيانات المستخدم العميل",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "governorateId": { "type": "string" },
        "isVip": { "type": "boolean", "default": false },
        "loyaltyPoints": { "type": "number", "default": 0 },
        "walletBalance": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "phone"]
    },
    "DriverProfile": {
      "title": "DriverProfile",
      "description": "بيانات المندوب",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "busy"] },
        "currentLocation": { "type": "object" },
        "rating": { "type": "number", "default": 5 }
      }
    },
    "Store": {
      "title": "Store",
      "description": "بيانات المتجر",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "deliveryTime": { "type": "string" },
        "governorateId": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "بيانات المنتج",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "options": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Order": {
      "title": "Order",
      "description": "بيانات الطلب",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "storeId": { "type": "string" },
        "driverId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "on_the_way", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "فئات المتاجر",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "المستخدمين" },
    "/drivers/{driverId}": { "schema": "DriverProfile", "description": "المندوبين" },
    "/stores/{storeId}": { "schema": "Store", "description": "المتاجر" },
    "/stores/{storeId}/products/{productId}": { "schema": "Product", "description": "المنتجات" },
    "/orders/{orderId}": { "schema": "Order", "description": "الطلبات" },
    "/categories/{categoryId}": { "schema": "Category", "description": "الفئات" },
    "/governorates/{governorateId}": { "schema": { "type": "object", "properties": { "name": { "type": "string" } } }, "description": "المحافظات" },
    "/ads/{adId}": { "schema": { "type": "object", "properties": { "imageUrl": { "type": "string" }, "link": { "type": "string" } } }, "description": "الإعلانات" },
    "/loyalty_points/{userId}": { "schema": { "type": "object", "properties": { "points": { "type": "number" } } }, "description": "نقاط الولاء" }
  }
}
